# Runtime Tool Authorization billing configuration
# Copy to .env locally. Do not commit real secrets.

# Stripe secret key. Use test mode locally.
STRIPE_SECRET_KEY=replace-with-stripe-secret-key

# Stripe webhook signing secret for local or deployed webhook endpoint.
STRIPE_WEBHOOK_SECRET=replace-with-webhook-signing-secret

# Recurring monthly price IDs from Stripe Dashboard.
STRIPE_PRICE_SOLO_MONTHLY=replace-with-solo-price-id
STRIPE_PRICE_TEAM_MONTHLY=replace-with-team-price-id
STRIPE_PRICE_DESIGN_PARTNER_MONTHLY=replace-with-design-partner-price-id

# Billing redirects.
BILLING_SUCCESS_URL=https://example.com/billing/success
BILLING_CANCEL_URL=https://example.com/billing/cancel
BILLING_PORTAL_RETURN_URL=https://example.com/account/billing

# Local pepper used to hash license keys and machine fingerprints.
# Use a long random secret in real environments.
LICENSE_KEY_PEPPER=replace-with-long-random-secret
